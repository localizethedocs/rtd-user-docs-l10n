#: ../../../config-file/v2.rst:848
msgid "search"
msgstr ""

#: ../../../config-file/v2.rst:850
msgid "Settings for more control over :doc:`/server-side-search/index`."
msgstr ""

#: ../../../config-file/v2.rst:852
msgid ""
"version: 2\n"
"\n"
"search:\n"
"  ranking:\n"
"    api/v1/*: -1\n"
"    api/v2/*: 4\n"
"  ignore:\n"
"    - 404.html"
msgstr ""

#: ../../../config-file/v2.rst:864
msgid "search.ranking"
msgstr ""

#: ../../../config-file/v2.rst:866
msgid "Set a custom search rank over pages matching a pattern."
msgstr ""

#: ../../../config-file/v2.rst:868
msgid "``map`` of patterns to ranks"
msgstr ""

#: ../../../config-file/v2.rst:871 ../../../config-file/v2.rst:922
msgid ""
"Patterns are matched against the relative paths of the HTML files produced "
"by the build, you should try to match ``index.html``, not ``docs/index."
"rst``, nor ``/en/latest/index.html``. Patterns can include one or more of "
"the following special characters:"
msgstr ""

#: ../../../config-file/v2.rst:875
msgid "``*`` matches everything, including slashes."
msgstr ""

#: ../../../config-file/v2.rst:876 ../../../config-file/v2.rst:927
msgid "``?`` matches any single character."
msgstr ""

#: ../../../config-file/v2.rst:877 ../../../config-file/v2.rst:928
msgid "``[seq]`` matches any character in ``seq``."
msgstr ""

#: ../../../config-file/v2.rst:879
msgid ""
"The rank can be an integer number between -10 and 10 (inclusive). Pages with "
"a rank closer to -10 will appear further down the list of results, and pages "
"with a rank closer to 10 will appear higher in the list of results. Note "
"that 0 means *normal rank*, not *no rank*."
msgstr ""

#: ../../../config-file/v2.rst:884
msgid ""
"If you are looking to completely ignore a page, check :ref:`config-file/v2:"
"search.ignore`."
msgstr ""

#: ../../../config-file/v2.rst:887
msgid ""
"version: 2\n"
"\n"
"search:\n"
"  ranking:\n"
"    # Match a single file\n"
"    tutorial.html: 2\n"
"\n"
"    # Match all files under the api/v1 directory\n"
"    api/v1/*: -5\n"
"\n"
"    # Match all files named guides.html,\n"
"    # two patterns are needed to match both the root and nested files.\n"
"    'guides.html': 3\n"
"    '*/guides.html': 3"
msgstr ""

#: ../../../config-file/v2.rst:906
msgid "The final rank will be the last pattern to match the page."
msgstr ""

#: ../../../config-file/v2.rst:910
msgid ""
"Is better to decrease the rank of pages you want to deprecate, rather than "
"increasing the rank of the other pages."
msgstr ""

#: ../../../config-file/v2.rst:914
msgid "search.ignore"
msgstr ""

#: ../../../config-file/v2.rst:916
msgid ""
"List of paths to ignore and exclude from the search index. Paths matched "
"will not be included in search results."
msgstr ""

#: ../../../config-file/v2.rst:919
msgid "``list`` of patterns"
msgstr ""

#: ../../../config-file/v2.rst:920
msgid "``['search.html', 'search/index.html', '404.html', '404/index.html']``"
msgstr ""

#: ../../../config-file/v2.rst:926
msgid "``*`` matches everything (including slashes)."
msgstr ""

#: ../../../config-file/v2.rst:930
msgid ""
"version: 2\n"
"\n"
"search:\n"
"   ignore:\n"
"     # Ignore a single file in the root of the output directory\n"
"     - 404.html\n"
"\n"
"     # Ignore all files under the search/ directory\n"
"     - search/*\n"
"\n"
"     # Ignore all files named ref.html,\n"
"     # two patterns are needed to match both the root and nested files.\n"
"     - 'ref.html'\n"
"     - '*/ref.html'"
msgstr ""

#: ../../../config-file/v2.rst:947
msgid ""
"version: 2\n"
"\n"
"search:\n"
"   ignore:\n"
"     # Custom files to ignore\n"
"     - file.html\n"
"     - api/v1/*\n"
"\n"
"     # Defaults\n"
"     - search.html\n"
"     - search/index.html\n"
"     - 404.html\n"
"     - 404/index.html"
msgstr ""

#: ../../../config-file/v2.rst:965
msgid ""
"Since Read the Docs fallbacks to the original search engine when no results "
"are found, you may still see search results from ignored pages."
msgstr ""

