msgstr ""

#: ../../../guides/manage-read-the-docs-teams.rst:38
msgid "Removing an owner from an organization"
msgstr ""

#: ../../../guides/manage-read-the-docs-teams.rst:40
msgid "To revoke administrative access from an organization owner:"
msgstr ""

#: ../../../guides/manage-read-the-docs-teams.rst:48
msgid "Click :guilabel:`Remove` next to the owner you want to remove."
msgstr ""

#: ../../../guides/manage-read-the-docs-teams.rst:52
msgid ""
"You cannot remove the last owner from an organization. There must always be "
"at least one owner."
msgstr ""

#: ../../../guides/manage-read-the-docs-teams.rst:56
msgid "Managing team members"
msgstr ""

#: ../../../guides/manage-read-the-docs-teams.rst:59
msgid "Adding a user to a team"
msgstr ""

