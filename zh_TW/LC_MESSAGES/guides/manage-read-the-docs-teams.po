#: ../../../guides/manage-read-the-docs-teams.rst:31
#: ../../../guides/manage-read-the-docs-teams.rst:33
msgid "Click :guilabel:`Invite owner`."
msgstr ""

#: ../../../guides/manage-read-the-docs-teams.rst:32
msgid "Enter the user's Read the Docs username or email address."
msgstr ""

